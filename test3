<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>خطة التداول - استراتيجية التذبذب</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f5f5f5;
            direction: rtl;
        }
        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        h1 {
            text-align: center;
            color: #2c3e50;
            margin-bottom: 30px;
        }
        .trading-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            font-size: 14px;
        }
        .trading-table th,
        .trading-table td {
            border: 1px solid #ddd;
            padding: 12px;
            text-align: center;
        }
        .trading-table th {
            background-color: #34495e;
            color: white;
            font-weight: bold;
        }
        .buy-row {
            background-color: #e8f5e8;
        }
        .sell-row {
            background-color: #ffe6e6;
        }
        .symbol-header {
            background-color: #27ae60;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }
        .calculator {
            background: #ecf0f1;
            padding: 20px;
            border-radius: 8px;
            margin: 20px 0;
        }
        .calculator input {
            padding: 8px;
            margin: 5px;
            border: 1px solid #bdc3c7;
            border-radius: 4px;
        }
        .calculator button {
            background: #27ae60;
            color: white;
            padding: 10px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        @media (max-width: 768px) {
            .trading-table {
                font-size: 12px;
            }
            .trading-table th,
            .trading-table td {
                padding: 8px 4px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📊 خطة التداول - استراتيجية التذبذب</h1>
        
        <!-- حاسبة المخاطرة -->
        <div class="calculator">
            <h3>🧮 حاسبة حجم المركز</h3>
            <input type="number" id="accountSize" placeholder="حجم الحساب ($)" style="width: 150px;">
            <input type="number" id="riskPercent" placeholder="نسبة المخاطرة %" value="2" style="width: 100px;">
            <button onclick="calculatePosition()">حساب حجم المركز</button>
            <div id="result" style="margin-top: 10px; font-weight: bold;"></div>
        </div>

        <table class="trading-table">
            <thead>
                <tr>
                    <th>الرمز</th>
                    <th>نوع الصفقة</th>
                    <th>سعر الدخول</th>
                    <th>الهدف 1</th>
                    <th>الهدف 2</th>
                    <th>وقف الخسارة</th>
                    <th>شرط الحجم</th>
                    <th>ملاحظات</th>
                </tr>
            </thead>
            <tbody>
                <tr class="buy-row">
                    <td rowspan="2" class="symbol-header">U</td>
                    <td>شراء</td>
                    <td>16.60</td>
                    <td>17.10</td>
                    <td>17.40</td>
                    <td>16.20</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Break above 16.60 w/ volume</td>
                </tr>
                <tr class="sell-row">
                    <td>بيع</td>
                    <td>16.20</td>
                    <td>15.80</td>
                    <td>15.50</td>
                    <td>16.60</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Break below 16.20 w/ volume</td>
                </tr>
                
                <tr class="buy-row">
                    <td rowspan="2" class="symbol-header">SONO</td>
                    <td>شراء</td>
                    <td>16.90</td>
                    <td>17.50</td>
                    <td>17.70</td>
                    <td>16.70</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Bounce from channel bottom</td>
                </tr>
                <tr class="sell-row">
                    <td>بيع</td>
                    <td>16.70</td>
                    <td>16.40</td>
                    <td>16.20</td>
                    <td>16.90</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Break below 16.70 w/ volume</td>
                </tr>
                
                <tr class="buy-row">
                    <td rowspan="2" class="symbol-header">BJ</td>
                    <td>شراء</td>
                    <td>76.20</td>
                    <td>77.80</td>
                    <td>78.50</td>
                    <td>74.80</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Break above 76.2 w/ volume</td>
                </tr>
                <tr class="sell-row">
                    <td>بيع</td>
                    <td>74.80</td>
                    <td>73.50</td>
                    <td>72.90</td>
                    <td>76.20</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Break below 74.8 w/ volume</td>
                </tr>
                
                <tr class="buy-row">
                    <td rowspan="2" class="symbol-header">BIGC</td>
                    <td>شراء</td>
                    <td>8.00</td>
                    <td>8.40</td>
                    <td>8.70</td>
                    <td>7.60</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Break above 8.00 w/ volume</td>
                </tr>
                <tr class="sell-row">
                    <td>بيع</td>
                    <td>7.60</td>
                    <td>7.30</td>
                    <td>7.00</td>
                    <td>8.00</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Break below 7.6 w/ volume</td>
                </tr>
                
                <tr class="buy-row">
                    <td rowspan="2" class="symbol-header">AI</td>
                    <td>شراء</td>
                    <td>25.00</td>
                    <td>26.20</td>
                    <td>26.80</td>
                    <td>24.40</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Bounce from 25.0 + MACD cross</td>
                </tr>
                <tr class="sell-row">
                    <td>بيع</td>
                    <td>24.40</td>
                    <td>23.60</td>
                    <td>23.00</td>
                    <td>25.00</td>
                    <td>Vol>1.5×20Bar</td>
                    <td>Break below 24.4 w/ volume</td>
                </tr>
            </tbody>
        </table>
    </div>

    <script>
        function calculatePosition() {
            const accountSize = parseFloat(document.getElementById('accountSize').value);
            const riskPercent = parseFloat(document.getElementById('riskPercent').value);
            
            if (!accountSize || !riskPercent) {
                document.getElementById('result').innerHTML = '⚠️ الرجاء إدخال جميع القيم';
                return;
            }
            
            const riskAmount = accountSize * (riskPercent / 100);
            let resultHTML = `<div style="color: #27ae60;">`;
            resultHTML += `مبلغ المخاطرة: ${riskAmount.toFixed(2)}<br>`;
            resultHTML += `لكل صفقة:<br>`;
            
            document.getElementById('result').innerHTML = resultHTML;
        }
    </script>
</body>
</html>
